# open-work Environment Variables for Coolify
# Copy this to Coolify's environment variables panel

# Required: Your OpenAI API key (or compatible provider)
OPENAI_API_KEY=

# Optional: Custom LLM endpoint (leave empty for OpenAI defaults)
# OPENWORK_API_KEY=

# Optional: Research API keys (increase rate limits)
OPENALEX_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=

# Optional: Frontend API URL override
# For Coolify, this is auto-set to http://api:8000
# NEXT_PUBLIC_API_URL=http://api:8000
